X		    wakeup(unit);
X		    return;
X		}
X	    } else if ((city2 = city_at(x, y)) != NULL) {
X		if (unit->side != city2->side) {
X		    wake_unit(unit); /* get everybody up! */
X		    return;
X		}
X	    }
X	}
X    }
