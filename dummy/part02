X/* average out things to keep peaks from getting too sharp */
X
Xsmooth_map(map)
Xint map[SIZE][SIZE];
X{
X    int x, y, ix, iy, sum;
X
X    for (x = 1; x < width-1; ++x) {
X	for (y = 1; y < height-1; ++y) {
X	    sum = 0;
X	    for (ix = x-1; ix <= x+1; ++ix)
X		for (iy = y-1; iy <= y+1; ++iy)
X		    sum += map[ix][iy];
X	    aux[x][y] = sum / 9;
X	}
