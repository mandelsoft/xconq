X/* Ensure that map values stay within given range */
X
Xlimit_map(map, hi, lo)
Xint map[SIZE][SIZE], hi, lo;
X{
X    int x, y;
X    
X    for (x = 0; x < width; ++x) {
X	for (y = 0; y < height; ++y) {
X	    if (map[x][y] > hi) map[x][y] = hi;
X	    if (map[x][y] < lo) map[x][y] = lo;
X	}
X    }
X}
