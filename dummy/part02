Xadd_maps(m1, m2, rslt)
Xint m1[SIZE][SIZE], m2[SIZE][SIZE], rslt[SIZE][SIZE];
X{
X    int x, y;
X
X    for (x = 0; x < width; ++x) {
X	for (y = 0; y < height; ++y) {
